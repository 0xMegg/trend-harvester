{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git reset --hard)",
      "Bash(git clean -fd)",
      "Bash(git commit * --no-verify *)",
      "Bash(git commit * -n *)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit -n*)",
      "Bash(chmod 777)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous.sh \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-branch-check.sh \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-check.sh \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-lint.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-test.sh \"$TOOL_INPUT\""
          },
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-size-check.sh \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/handoff-freshness-check.sh"
          }
        ]
      }
    ]
  }
}
